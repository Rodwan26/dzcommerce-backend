# =============================================================================
# DzCommerce — Environment Configuration
# =============================================================================
# Production: Set ALL of these via Render Dashboard (not in .env on Render).
# Local dev:  Copy this file to .env and adjust values.
# =============================================================================

APP_NAME=DzCommerce
DEBUG=false

# Production: Paste full Neon connection string WITH sslmode=require
# Example: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/dzcommerce?sslmode=require
DATABASE_URL=postgresql+asyncpg://dzcommerce:dzcommerce@localhost:5432/dzcommerce

# Production: Generate a strong random key (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

TRIAL_DAYS=15

# Production: Add your Vercel frontend URL
# Example: ["http://localhost:3000","https://dzcommerce.vercel.app"]
CORS_ORIGINS=["http://localhost:3000"]

# Not used in production (no Redis required at current stage)
REDIS_URL=redis://localhost:6379/0

FACEBOOK_MOCK_MODE=true
